{
  "name": "containerlab-app",
  "version": "0.0.1",
  "private": true,
  "description": "Workspace for Containerlab web and desktop hosts.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace containerlab-web",
    "dev:web:local": "npm run dev:local --workspace containerlab-web",
    "dev:desktop": "npm run dev --workspace containerlab-desktop",
    "build": "npm run build:web && npm run build:desktop",
    "build:web": "npm run build --workspace containerlab-web",
    "build:desktop": "npm run build --workspace containerlab-desktop",
    "package:desktop": "npm run package --workspace containerlab-desktop",
    "package:desktop:linux": "npm run package:linux --workspace containerlab-desktop",
    "package:desktop:win": "npm run package:win --workspace containerlab-desktop",
    "start:web": "npm run start --workspace containerlab-web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:local-ui": "npm run typecheck:local-ui --workspace containerlab-web",
    "lint": "npm run lint --workspaces --if-present",
    "lint:ts": "oxlint --import-plugin --react-plugin --jsx-a11y-plugin apps packages",
    "lint:ts:fix": "oxlint --import-plugin --react-plugin --jsx-a11y-plugin apps packages --fix --fix-suggestions",
    "test:unit": "node --import tsx --test 'packages/**/*.test.ts' 'packages/**/*.test.tsx'",
    "test:e2e:web": "npm run test:e2e --workspace containerlab-web",
    "test:e2e:web:local-ui": "npm run test:e2e:local-ui --workspace containerlab-web",
    "test:e2e:web:smoke": "npm run test:e2e:smoke --workspace containerlab-web",
    "check:local-clab-ui": "node scripts/check-local-clab-ui.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.7",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.18.1",
    "postcss": "^8.5.10",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
