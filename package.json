{
  "name": "containerlab-web",
  "version": "0.0.1",
  "private": true,
  "description": "Standalone browser runtime for containerlab built on @srl-labs/clab-ui.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development concurrently -k -n server,vite \"tsx watch server/index.ts\" \"sh -c 'until curl -sSf http://localhost:${PORT:-3000}/api/config >/dev/null 2>&1; do sleep 0.2; done; vite --config vite.config.ts --force'\"",
    "build": "vite build --config vite.config.ts && npm run build:server",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=cjs --target=node24 --outfile=dist/server/index.cjs --sourcemap",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test:unit": "node --import tsx --test src/**/*.test.ts server/**/*.test.ts",
    "test:e2e": "playwright test --config test/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config test/e2e/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config test/e2e/playwright.config.ts --debug",
    "start": "NODE_ENV=production node dist/server/index.cjs",
    "preview": "vite preview --config vite.config.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.2.0",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@srl-labs/clab-ui": "0.0.21",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ajv": "^8.18.0",
    "fastify": "^5.3.3",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.20.0",
    "yaml": "^2.8.2",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.1.2",
    "esbuild": "^0.27.3",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
