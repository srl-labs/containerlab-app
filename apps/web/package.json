{
  "name": "containerlab-app-web",
  "version": "0.2.0",
  "private": true,
  "description": "Browser host for containerlab-app built on @srl-labs/clab-ui.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development concurrently -k -n server,vite \"tsx watch server/index.ts\" \"sh -c 'node ../../scripts/wait-web-server.mjs && vite --config vite.config.ts'\"",
    "dev:local": "node ../../scripts/check-local-clab-ui.mjs && NODE_ENV=development CLAB_UI_SOURCE=local concurrently -k -n server,vite \"tsx watch --tsconfig tsconfig.server.local-ui.runtime.json server/index.ts\" \"sh -c 'node ../../scripts/wait-web-server.mjs && vite --config vite.config.ts'\"",
    "dev:pages": "NODE_ENV=development VITE_CLAB_RUNTIME_MODE=pages vite --config vite.config.ts",
    "dev:pages:local": "node ../../scripts/check-local-clab-ui.mjs && NODE_ENV=development CLAB_UI_SOURCE=local VITE_CLAB_RUNTIME_MODE=pages vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts && npm run build:server",
    "build:pages": "VITE_CLAB_RUNTIME_MODE=pages vite build --config vite.config.ts",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=cjs --target=node24 --outfile=dist/server/index.cjs --sourcemap",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "typecheck:local-ui": "node ../../scripts/check-local-clab-ui.mjs && tsc -p tsconfig.local-ui.json --noEmit && tsc -p tsconfig.server.local-ui.json --noEmit",
    "lint": "npm run typecheck && npm run lint:ts",
    "lint:ts": "oxlint --import-plugin --react-plugin --jsx-a11y-plugin .",
    "lint:ts:fix": "oxlint --import-plugin --react-plugin --jsx-a11y-plugin . --fix --fix-suggestions",
    "test:unit": "node --import tsx --test ../../packages/app-server/src/**/*.test.ts ../../packages/standalone-runtime/src/**/*.test.ts",
    "test:e2e": "playwright test --config test/e2e/playwright.config.ts",
    "test:e2e:local-ui": "CLAB_UI_SOURCE=local playwright test --config test/e2e/playwright.config.ts",
    "test:e2e:smoke": "playwright test --config test/e2e/playwright.config.ts test/e2e/specs/standalone-smoke.spec.ts --project=chromium",
    "test:e2e:smoke:local-ui": "CLAB_UI_SOURCE=local playwright test --config test/e2e/playwright.config.ts test/e2e/specs/standalone-smoke.spec.ts --project=chromium",
    "test:e2e:ui": "playwright test --config test/e2e/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config test/e2e/playwright.config.ts --debug",
    "start": "NODE_ENV=production node dist/server/index.cjs",
    "preview": "vite preview --config vite.config.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "^9.3.0",
    "@fastify/websocket": "^11.2.0",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.10",
    "@srl-labs/containerlab-app-server": "0.2.0",
    "@srl-labs/containerlab-standalone-runtime": "0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ajv": "^8.18.0",
    "fastify": "^5.8.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.184.0",
    "ws": "^8.21.0",
    "yaml": "^2.8.3",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.7",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.18.1",
    "postcss": "^8.5.10",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2"
  }
}
