{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@srl-labs/containerlab-app-contract": ["./packages/app-contract/src/index.ts"],
      "@srl-labs/containerlab-app-server": ["./packages/app-server/src/index.ts"],
      "@srl-labs/containerlab-standalone-runtime": ["./packages/standalone-runtime/src/index.ts"],
      "@srl-labs/containerlab-standalone-runtime/terminal-main": [
        "./packages/standalone-runtime/src/terminalMain.tsx"
      ],
      "@srl-labs/containerlab-standalone-runtime/web-main": ["./packages/standalone-runtime/src/main.tsx"],
      "@srl-labs/containerlab-standalone-runtime/wireshark-vnc-main": [
        "./packages/standalone-runtime/src/wiresharkVncMain.tsx"
      ]
    }
  }
}
